# ===== LLM Provider (admin 服务使用) =====
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-opus-4-5

# ===== MongoDB =====
MONGO_URI=mongodb://mongo:27017
MONGO_DB=pi_agent

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Gateway =====
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0

# ===== Admin =====
ADMIN_PORT=9000
ADMIN_HOST=0.0.0.0

# ===== Pi Runtime =====
# pi-runtime 内部使用 admin 作为 LLM 代理
OPENAI_BASE_URL=http://admin:9000/v1
OPENAI_API_KEY=pi-agent-internal

# bwrap 沙盒根目录（容器内路径）
# users/{user_id}/workspace/ 和 home/ 跨 session 持久化保留
SANDBOX_ROOT=/data/sandboxes
