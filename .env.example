# ===== LLM Provider (admin 服务使用) =====
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-opus-4-5

# ===== MongoDB =====
MONGO_URI=mongodb://mongo:27017
MONGO_DB=pi_agent

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Gateway =====
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0

# ===== Admin =====
ADMIN_PORT=9000
ADMIN_HOST=0.0.0.0

# ===== Pi Runtime =====
# pi-runtime 内部使用 admin 作为 LLM 代理
OPENAI_BASE_URL=http://admin:9000/v1
OPENAI_API_KEY=pi-agent-internal

# bwrap 沙盒根目录（容器内路径）
# 结构：{SANDBOX_ROOT}/users/{user_id}/workspace/  → 持久化
#        {SANDBOX_ROOT}/users/{user_id}/home/       → 持久化
#        {SANDBOX_ROOT}/users/{user_id}/sessions/{sid}/tmp/ → 临时
SANDBOX_ROOT=/data/sandboxes

# ===== 生产集群共享存储（docker-compose.prod.yml 使用）=====
# NFS 自建
NFS_SERVER_ADDR=192.168.1.100
NFS_EXPORT_PATH=/data/pi-sandboxes

# AWS EFS（与 NFS 二选一）
# EFS_DNS_NAME=fs-xxxxxxxx.efs.ap-east-1.amazonaws.com

# 阿里云 NAS（与 NFS 二选一）
# NAS_SERVER_ADDR=xxxxxxxx.nas.aliyuncs.com
# NAS_EXPORT_PATH=/
