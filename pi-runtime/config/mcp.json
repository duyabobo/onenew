{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/workspace"],
      "description": "沙盒内文件系统读写（限制在 /workspace 目录）"
    },
    "http-client": {
      "command": "node",
      "args": ["/app/extensions/mcp-servers/http-client.js"],
      "description": "HTTP 请求工具（沙盒外执行，可访问网络）"
    },
    "database": {
      "command": "node",
      "args": ["/app/extensions/mcp-servers/database.js"],
      "env": {
        "DB_URI": "${MONGO_URI}",
        "DB_NAME": "${MONGO_DB}"
      },
      "description": "数据库查询工具"
    }
  }
}
